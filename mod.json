{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "esilagd.multiplayer",
	"name": "Multiplayer",
	"version": "1.10",
	"developer": "Esilagd",
	"description": "a multiplayer for versus",
	"dependencies": {
		"geode.node-ids": ">=v1.23.3"
        "homepage": "https://www.multiplayer.com",
        "source": "https://github.com/",
        "community": "https://discord.com/"
    },
    "tags": [
        "online", "offline"
    ],
    "settings": {
        "force-no-preload": {
            "type": "trail",
            "name": "Disable trail",
            "description": "disable trail of other player (you wont see other player trail or wave trail).",
            "default": false
    },
    "resources": {
        "sprites": [
            "resources/menu/*.png",
            "resources/featured/*.png",
            "resources/roles/*.png",
            "resources/game/*.png"
        ],

        "files": [
    "api": {
        "include": [
            "include/multiplayer/core/*.hpp",
            "include/multiplayer/core/data/*.hpp",
            "include/multiplayer/core/game/*.hpp",
            "include/multiplayer/core/net/*.hpp",
            "include/multiplayer/soft-link/*.hpp",
            "include/multiplayer/util/*.hpp"
        ]
    }
}
